# ─── Configuração do Agente LLM Autónomo ─────────────────────────────────────

# LLM Principal — DeepSeek (obrigatório para o agente funcionar)
# Obtém em: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Bot Telegram (obrigatório)
# Cria em: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# O teu ID no Telegram (para o bot só responder a ti)
# Obtém em: https://t.me/userinfobot
OWNER_TELEGRAM_ID=123456789

# GitHub (para o agente fazer commits e push)
# Obtém em: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=treis335/agentsbot

# Caminho local do repositório (onde corre no teu PC)
REPO_LOCAL_PATH=C:\Users\Crypto Bull\Desktop\Agente Local

# ─── Configurações Avançadas ──────────────────────────────────────────────────

# Número máximo de iterações de ferramentas por mensagem (padrão: 5)
# Aumenta se quiseres que o agente faça tarefas mais complexas
LLM_MAX_TOOL_ITERATIONS=5

# Histórico de conversa mantido (últimas N mensagens)
LLM_MAX_HISTORY=30

# Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
