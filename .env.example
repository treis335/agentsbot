# ============================================================
# CORREOTO ECOSYSTEM — Configuração
# Copia este ficheiro para .env e preenche os valores
# ============================================================

# --- TELEGRAM (obrigatório para bot funcionar) ---
TELEGRAM_BOT_TOKEN=cole_aqui_o_token_do_botfather
OWNER_TELEGRAM_ID=cole_aqui_o_teu_id_do_telegram

# --- INFERÊNCIA LLM (escolhe um modo) ---

# MODO A: Só Ollama local (grátis, GPU/CPU)
# Deixa DEEPSEEK_API_KEY vazio → usa sempre Ollama
DEEPSEEK_API_KEY=
OLLAMA_URL=http://localhost:11434
LOCAL_MODEL=qwen2.5-coder:7b

# MODO B: DeepSeek cloud + Ollama como fallback
# DEEPSEEK_API_KEY=sk-...
# OLLAMA_URL=http://localhost:11434
# LOCAL_MODEL=qwen2.5-coder:7b

# MODO C: Só DeepSeek (sem Ollama)
# DEEPSEEK_API_KEY=sk-...

# --- ROUTING (só relevante se usares ambos) ---
# 0.0 = sempre DeepSeek | 1.0 = sempre Ollama | 0.4 = recomendado (tarefas simples→Ollama)
ROUTING_THRESHOLD=0.4
OLLAMA_TIMEOUT=120

# --- GIT/GITHUB ---
GITHUB_TOKEN=ghp_...
GITHUB_REPO=treis335/agentsbot
REPO_LOCAL_PATH=C:\Users\Crypto Bull\Desktop\Agente Local

# --- DEEPSEEK (opcional se usares Ollama) ---
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- SISTEMA ---
LOG_LEVEL=INFO
AGENT_INTERVAL=300
SANDBOX_ENABLED=false

# --- SELF-IMPROVEMENT ---
SELF_IMPROVE_ENABLED=true
SELF_IMPROVE_EVERY_N_CYCLES=10
SELF_IMPROVE_MAX_PATCHES=3

# --- NOTIFICAÇÕES ---
NOTIFY_ON_TASK_COMPLETE=true
NOTIFY_ON_TASK_FAIL=true
NOTIFY_ON_SELF_IMPROVE=true
NOTIFY_DAILY_SUMMARY=true
NOTIFY_DAILY_SUMMARY_HOUR=8

# ── Modo Económico (poupar chamadas API) ──────────────────────────────────────
# Intervalo entre ciclos do loop autónomo (segundos). Default: 120 (2 min)
# Mais baixo = mais activo mas mais caro. Mínimo recomendado: 60
CYCLE_INTERVAL_SECONDS=120

# Cooldown entre debates do OrganicMind quando backlog vazio (segundos). Default: 600 (10 min)
DEBATE_COOLDOWN_SECONDS=600

# Máximo de agentes por debate (cada agente = 1 chamada API). Default: 2
MAX_DEBATE_AGENTS=2

# Máximo de iterações de ferramentas por tarefa. Default: 12
MAX_TOOL_ITERATIONS=12

# Tokens máximos por chamada LLM. Default: 800
DEFAULT_MAX_TOKENS=800

# Tokens por pensamento de agente no debate. Default: 200
AGENT_THINK_TOKENS=200

# Brainstorm colaborativo a cada N ciclos. Default: 20
BRAINSTORM_EVERY_N_CYCLES=20
